# Catalyst — example environment. Copy to .env and fill in only if you want BYOK.
# .env is gitignored. Never commit real keys.
#
# BYOK is OPTIONAL. With no key set, the control panel runs in mock mode and
# makes no network calls. A key only powers AI-assisted synthesis/review.

# --- BYOK (optional) ---
# OpenRouter is the first supported provider.
OPENROUTER_API_KEY=
# Generic fallback key var (used if OPENROUTER_API_KEY is unset).
CATALYST_API_KEY=
# Provider + model selection (only used when a key is present).
CATALYST_PROVIDER=mock
CATALYST_MODEL=openrouter/auto

# --- Control panel server (optional) ---
# Defaults are localhost-only and safe. Change host only if you know why.
CATALYST_HOST=127.0.0.1
CATALYST_PORT=8765
# Required ONLY if you bind a non-local host. Leave empty for localhost.
CATALYST_TOKEN=
